        {
          "id": "12.5.1",
          "title": "Self-Service Tenant Onboarding API",
          "dimension": "tenant_onboarding",
          "description": "Enable software to request tenant provisioning without manual intervention",
          "objectives": [
            "REST API endpoint accepts tenant registration request",
            "Tenant record created; database provisioned with initial schema",
            "JWT credentials issued and sent to admin email",
            "Audit log captures onboarding event",
            "End-to-end integration tests validate registration flow"
          ],
          "prerequisites": [
            "Phases 0–11 complete"
          ],
          "dependencies": [],
          "readiness_gates": {
            "entry": [
              "Phase 11 complete",
              "Tenant isolation audit passed",
              "Security review approved"
            ],
            "exit": [
              "Onboarding API tested end-to-end",
              "Audit logging covers all tenant CRUD",
              "Compliance impact doc updated"
            ]
          },
          "estimated_effort": "M",
          "estimated_timeline_weeks": 4,
          "scope": ["Backend API", "Integration Tests", "Documentation"],
          "success_metrics": {
            "onboarding_time": "<15 minutes from API call to provisioned",
            "self_service_adoption": ">80% within 6 months",
            "audit_coverage": "100% of tenant CRUD events logged"
          }
        },
        {
