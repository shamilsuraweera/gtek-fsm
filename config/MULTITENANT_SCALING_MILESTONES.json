            ],
            "exit": [
              "SSO integration tested with mock IdP",
              "MFA enrollment/recovery tested",
              "Security audit passed"
            ]
          },
          "estimated_effort": "M",
          "estimated_timeline_weeks": 5,
          "scope": ["Backend Identity Service", "Portal MFA/SSO Settings", "Integration & E2E Tests"]
        },
