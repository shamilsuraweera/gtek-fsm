<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- ========================================
         COLORS - Neutral Palette
         ======================================== -->

    <!-- Grayscale (neutral) -->
    <Color x:Key="ColorGray50">#FAFAFA</Color>
    <Color x:Key="ColorGray100">#F5F5F5</Color>
    <Color x:Key="ColorGray200">#E8E8E8</Color>
    <Color x:Key="ColorGray300">#D4D4D4</Color>
    <Color x:Key="ColorGray400">#A3A3A3</Color>
    <Color x:Key="ColorGray500">#737373</Color>
    <Color x:Key="ColorGray600">#525252</Color>
    <Color x:Key="ColorGray700">#404040</Color>
    <Color x:Key="ColorGray800">#262626</Color>
    <Color x:Key="ColorGray900">#171717</Color>
    <Color x:Key="ColorGray950">#0A0A0A</Color>

    <!-- Semantic Colors - Light Variants -->
    <Color x:Key="ColorBgPageLight">#FBFBFC</Color>
    <Color x:Key="ColorBgSurfaceLight">#F5F7F9</Color>
    <Color x:Key="ColorBgSurfaceElevatedLight">#FFFFFF</Color>
    <Color x:Key="ColorTextPrimaryLight">#2B435F</Color>
    <Color x:Key="ColorTextSecondaryLight">#43596F</Color>
    <Color x:Key="ColorTextMutedLight">#6F7E8D</Color>
    <Color x:Key="ColorTextDisabledLight">#A3A3A3</Color>
    <Color x:Key="ColorBorderDefaultLight">#E4E9EF</Color>
    <Color x:Key="ColorBorderSubtleLight">#F5F7F9</Color>
    <Color x:Key="ColorBorderStrongLight">#D2DBE4</Color>
    <Color x:Key="ColorAccentLight">#F38808</Color>
    <Color x:Key="ColorAccentHoverLight">#D97306</Color>
    <Color x:Key="ColorAccentActiveLight">#B85F03</Color>
    <Color x:Key="ColorAccentBgLight">#FFF3E3</Color>

    <!-- Semantic Colors - Dark Variants -->
    <Color x:Key="ColorBgPageDark">#2B435F</Color>
    <Color x:Key="ColorBgSurfaceDark">#35506C</Color>
    <Color x:Key="ColorBgSurfaceElevatedDark">#40607F</Color>
    <Color x:Key="ColorTextPrimaryDark">#FFFFFF</Color>
    <Color x:Key="ColorTextSecondaryDark">#EAF0F6</Color>
    <Color x:Key="ColorTextMutedDark">#D3DCE5</Color>
    <Color x:Key="ColorTextDisabledDark">#6B7280</Color>
    <Color x:Key="ColorBorderDefaultDark">#4A6077</Color>
    <Color x:Key="ColorBorderSubtleDark">#35506C</Color>
    <Color x:Key="ColorBorderStrongDark">#5D7590</Color>
    <Color x:Key="ColorAccentDark">#F6A74A</Color>
    <Color x:Key="ColorAccentHoverDark">#F8B862</Color>
    <Color x:Key="ColorAccentActiveDark">#D98A2B</Color>
    <Color x:Key="ColorAccentBgDark">#5C4A34</Color>

    <!-- Status Colors - Light Variants -->
    <Color x:Key="ColorStatusSuccessLight">#10B981</Color>
    <Color x:Key="ColorStatusSuccessBgLight">#D1FAE5</Color>
    <Color x:Key="ColorStatusErrorLight">#EF4444</Color>
    <Color x:Key="ColorStatusErrorBgLight">#FEE2E2</Color>
    <Color x:Key="ColorStatusWarningLight">#F59E0B</Color>
    <Color x:Key="ColorStatusWarningBgLight">#FEF3C7</Color>
    <Color x:Key="ColorStatusInfoLight">#3B82F6</Color>
    <Color x:Key="ColorStatusInfoBgLight">#DBEAFE</Color>

    <!-- Status Colors - Dark Variants -->
    <Color x:Key="ColorStatusSuccessDark">#10B981</Color>
    <Color x:Key="ColorStatusSuccessBgDark">#064E3B</Color>
    <Color x:Key="ColorStatusErrorDark">#F87171</Color>
    <Color x:Key="ColorStatusErrorBgDark">#7F1D1D</Color>
    <Color x:Key="ColorStatusWarningDark">#FBBF24</Color>
    <Color x:Key="ColorStatusWarningBgDark">#78350F</Color>
    <Color x:Key="ColorStatusInfoDark">#60A5FA</Color>
    <Color x:Key="ColorStatusInfoBgDark">#1E3A8A</Color>

    <!-- AppThemeBinding Colors (automatic light/dark) -->
    <Color x:Key="ColorBgPage">#FFFFFF</Color>
    <Color x:Key="ColorBgSurface">#F5F5F5</Color>
    <Color x:Key="ColorBgSurfaceElevated">#FFFFFF</Color>
    <Color x:Key="ColorTextPrimary">#000000</Color>
    <Color x:Key="ColorTextSecondary">#404040</Color>
    <Color x:Key="ColorTextMuted">#737373</Color>
    <Color x:Key="ColorTextDisabled">#A3A3A3</Color>
    <Color x:Key="ColorBorderDefault">#E8E8E8</Color>
    <Color x:Key="ColorBorderSubtle">#F5F5F5</Color>
    <Color x:Key="ColorBorderStrong">#D4D4D4</Color>
    <Color x:Key="ColorAccent">#0F6ABD</Color>
    <Color x:Key="ColorAccentHover">#0B4A85</Color>
    <Color x:Key="ColorAccentActive">#073157</Color>
    <Color x:Key="ColorAccentBg">#E0F2FE</Color>
    <Color x:Key="ColorStatusSuccess">#10B981</Color>
    <Color x:Key="ColorStatusSuccessBg">#D1FAE5</Color>
    <Color x:Key="ColorStatusError">#EF4444</Color>
    <Color x:Key="ColorStatusErrorBg">#FEE2E2</Color>
    <Color x:Key="ColorStatusWarning">#F59E0B</Color>
    <Color x:Key="ColorStatusWarningBg">#FEF3C7</Color>
    <Color x:Key="ColorStatusInfo">#3B82F6</Color>
    <Color x:Key="ColorStatusInfoBg">#DBEAFE</Color>

    <!-- ========================================
         SPACING - 4px Base Scale
         ======================================== -->
    <x:Double x:Key="SpacingXs">4</x:Double>
    <x:Double x:Key="SpacingSm">8</x:Double>
    <x:Double x:Key="SpacingMd">16</x:Double>
    <x:Double x:Key="SpacingLg">24</x:Double>
    <x:Double x:Key="SpacingXl">32</x:Double>
    <x:Double x:Key="Spacing2xl">48</x:Double>
    <x:Double x:Key="Spacing3xl">64</x:Double>

    <!-- ========================================
         TYPOGRAPHY - Font Families & Sizing
         ======================================== -->
    
    <!-- Font Families (MAUI defaults) -->
    <x:String x:Key="FontFamilyPrimary">Segoe UI</x:String>
    <x:String x:Key="FontFamilyMono">Courier New</x:String>

    <!-- Font Sizes -->
    <x:Double x:Key="FontSizeDisplay">48</x:Double>
    <x:Double x:Key="FontSizeH1">32</x:Double>
    <x:Double x:Key="FontSizeH2">24</x:Double>
    <x:Double x:Key="FontSizeH3">20</x:Double>
    <x:Double x:Key="FontSizeH4">18</x:Double>
    <x:Double x:Key="FontSizeH5">16</x:Double>
    <x:Double x:Key="FontSizeH6">14</x:Double>
    <x:Double x:Key="FontSizeBodyLarge">18</x:Double>
    <x:Double x:Key="FontSizeBody">16</x:Double>
    <x:Double x:Key="FontSizeBodySmall">14</x:Double>
    <x:Double x:Key="FontSizeLabel">14</x:Double>
    <x:Double x:Key="FontSizeCaption">12</x:Double>
    <x:Double x:Key="FontSizeButton">16</x:Double>

    <!-- ========================================
         ELEVATION - Shadow System (MAUI)
         Note: MAUI uses HasShadow boolean on Frame
         ======================================== -->
    <!-- No direct shadow values, use Frame.HasShadow property -->

    <!-- ========================================
         BORDER RADIUS
         ======================================== -->
    <x:Double x:Key="RadiusNone">0</x:Double>
    <x:Double x:Key="RadiusSm">2</x:Double>
    <x:Double x:Key="RadiusMd">4</x:Double>
    <x:Double x:Key="RadiusLg">8</x:Double>
    <x:Double x:Key="RadiusXl">12</x:Double>

    <!-- ========================================
         ANIMATION DURATIONS (milliseconds)
         ======================================== -->
    <x:Int32 x:Key="DurationFast">100</x:Int32>
    <x:Int32 x:Key="DurationNormal">200</x:Int32>
    <x:Int32 x:Key="DurationSlow">300</x:Int32>

    <!-- ========================================
         STYLE PRESETS
         ======================================== -->

    <!-- Heading Styles -->
    <Style x:Key="StyleHeadingH1" TargetType="Label">
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyPrimary}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeH1}" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="LineBreakMode" Value="WordWrap" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource ColorTextPrimaryLight}, Dark={StaticResource ColorTextPrimaryDark}}" />
    </Style>

    <Style x:Key="StyleHeadingH2" TargetType="Label">
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyPrimary}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeH2}" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="LineBreakMode" Value="WordWrap" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource ColorTextPrimaryLight}, Dark={StaticResource ColorTextPrimaryDark}}" />
    </Style>

    <Style x:Key="StyleHeadingH3" TargetType="Label">
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyPrimary}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeH3}" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="LineBreakMode" Value="WordWrap" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource ColorTextPrimaryLight}, Dark={StaticResource ColorTextPrimaryDark}}" />
    </Style>

    <!-- Body Text Styles -->
    <Style x:Key="StyleBodyDefault" TargetType="Label">
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyPrimary}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}" />
        <Setter Property="LineBreakMode" Value="WordWrap" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource ColorTextPrimaryLight}, Dark={StaticResource ColorTextPrimaryDark}}" />
    </Style>

    <Style x:Key="StyleBodySmall" TargetType="Label">
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyPrimary}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeBodySmall}" />
        <Setter Property="LineBreakMode" Value="WordWrap" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource ColorTextPrimaryLight}, Dark={StaticResource ColorTextPrimaryDark}}" />
    </Style>

    <!-- UI Text Styles -->
    <Style x:Key="StyleLabel" TargetType="Label">
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyPrimary}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeLabel}" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource ColorTextPrimaryLight}, Dark={StaticResource ColorTextPrimaryDark}}" />
    </Style>

    <Style x:Key="StyleCaption" TargetType="Label">
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyPrimary}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource ColorTextMutedLight}, Dark={StaticResource ColorTextMutedDark}}" />
    </Style>

    <!-- Status Text Styles -->
    <Style x:Key="StyleTextSuccess" TargetType="Label">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource ColorStatusSuccessLight}, Dark={StaticResource ColorStatusSuccessDark}}" />
    </Style>

    <Style x:Key="StyleTextError" TargetType="Label">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource ColorStatusErrorLight}, Dark={StaticResource ColorStatusErrorDark}}" />
    </Style>

    <!-- Stack Layout Presets with Spacing -->
    <Style x:Key="StyleStackTight" TargetType="VerticalStackLayout">
        <Setter Property="Spacing" Value="{StaticResource SpacingSm}" />
        <Setter Property="Padding" Value="{StaticResource SpacingMd}" />
    </Style>

    <Style x:Key="StyleStackDefault" TargetType="VerticalStackLayout">
        <Setter Property="Spacing" Value="{StaticResource SpacingMd}" />
        <Setter Property="Padding" Value="{StaticResource SpacingMd}" />
    </Style>

    <Style x:Key="StyleStackRelaxed" TargetType="VerticalStackLayout">
        <Setter Property="Spacing" Value="{StaticResource SpacingLg}" />
        <Setter Property="Padding" Value="{StaticResource SpacingLg}" />
    </Style>

    <!-- Card/Frame Styles -->
    <Style x:Key="StyleCardDefault" TargetType="Frame">
        <Setter Property="Padding" Value="{StaticResource SpacingMd}" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusLg}" />
        <Setter Property="BorderColor" Value="{AppThemeBinding Light={StaticResource ColorBorderDefaultLight}, Dark={StaticResource ColorBorderDefaultDark}}" />
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource ColorBgSurfaceLight}, Dark={StaticResource ColorBgSurfaceDark}}" />
    </Style>

</ResourceDictionary>
