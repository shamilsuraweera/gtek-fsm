<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Legacy keys mapped to the simplified mobile palette -->
    <Color x:Key="Primary">#E18B2C</Color>
    <Color x:Key="Light">#E18B2C</Color>
    <Color x:Key="Dark">#182435</Color>
    <Color x:Key="White">White</Color>
    <Color x:Key="Black">Black</Color>
    <Color x:Key="LightGray">#D5DEEA</Color>
    <Color x:Key="MidGray">#6C7D94</Color>
    <Color x:Key="DarkGray">#344A63</Color>
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}"/>
    <SolidColorBrush x:Key="LightBrush" Color="{StaticResource Light}"/>
    <SolidColorBrush x:Key="DarkBrush" Color="{StaticResource Dark}"/>
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}"/>
    <SolidColorBrush x:Key="LightGrayBrush" Color="{StaticResource LightGray}"/>
    <SolidColorBrush x:Key="MidGrayBrush" Color="{StaticResource MidGray}"/>
    <SolidColorBrush x:Key="DarkGrayBrush" Color="{StaticResource DarkGray}"/>

    <Color x:Key="Yellow100Accent">#F4A748</Color>
    <Color x:Key="Yellow200Accent">#F8C27E</Color>
    <Color x:Key="Yellow300Accent">#FCE1BA</Color>
    <Color x:Key="Cyan100Accent">#5A738D</Color>
    <Color x:Key="Cyan200Accent">#7F96AD</Color>
    <Color x:Key="Cyan300Accent">#B9C7D4</Color>
    <Color x:Key="Blue100Accent">#2B435F</Color>
    <Color x:Key="Blue200Accent">#4A6077</Color>
    <Color x:Key="Blue300Accent">#93A4B5</Color>

    <!-- Semantic tokens for mobile screens and components -->
    <Color x:Key="ColorBgPageLight">#F3F6FB</Color>
    <Color x:Key="ColorBgPageDark">#0E1521</Color>
    <Color x:Key="ColorBgSurfaceLight">#FFFFFF</Color>
    <Color x:Key="ColorBgSurfaceDark">#141E2C</Color>
    <Color x:Key="ColorTextPrimaryLight">#1E2A3A</Color>
    <Color x:Key="ColorTextPrimaryDark">#F3F7FD</Color>
    <Color x:Key="ColorTextMutedLight">#5A6C84</Color>
    <Color x:Key="ColorTextMutedDark">#A7B6CB</Color>
    <Color x:Key="ColorBorderDefaultLight">#D8E1EC</Color>
    <Color x:Key="ColorBorderDefaultDark">#293A52</Color>
    <Color x:Key="ColorAccentLight">#E18B2C</Color>
    <Color x:Key="ColorAccentDark">#F1A44A</Color>

    <SolidColorBrush x:Key="ColorBgPageBrush"
                     Color="{AppThemeBinding Light={StaticResource ColorBgPageLight}, Dark={StaticResource ColorBgPageDark}}"/>
    <SolidColorBrush x:Key="ColorBgSurfaceBrush"
                     Color="{AppThemeBinding Light={StaticResource ColorBgSurfaceLight}, Dark={StaticResource ColorBgSurfaceDark}}"/>
    <SolidColorBrush x:Key="ColorTextPrimaryBrush"
                     Color="{AppThemeBinding Light={StaticResource ColorTextPrimaryLight}, Dark={StaticResource ColorTextPrimaryDark}}"/>
    <SolidColorBrush x:Key="ColorTextMutedBrush"
                     Color="{AppThemeBinding Light={StaticResource ColorTextMutedLight}, Dark={StaticResource ColorTextMutedDark}}"/>
    <SolidColorBrush x:Key="ColorBorderDefaultBrush"
                     Color="{AppThemeBinding Light={StaticResource ColorBorderDefaultLight}, Dark={StaticResource ColorBorderDefaultDark}}"/>
    <SolidColorBrush x:Key="ColorAccentBrush"
                     Color="{AppThemeBinding Light={StaticResource ColorAccentLight}, Dark={StaticResource ColorAccentDark}}"/>

</ResourceDictionary>