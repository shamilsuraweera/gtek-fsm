<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GTEK.FSM.MobileApp.Pages.Worker.SettingsPage"
             Title="Settings">
       <ScrollView>
              <VerticalStackLayout Padding="20,18,20,24" Spacing="12">
                     <Label Text="Settings" FontSize="28" FontAttributes="Bold" />
                     <Label Text="The worker settings view now follows the same simplified white/orange/slate presentation."
                               TextColor="{AppThemeBinding Light={StaticResource ColorTextMutedLight}, Dark={StaticResource ColorTextMutedDark}}" />

                     <Border Padding="16" BackgroundColor="{AppThemeBinding Light={StaticResource ColorBgSurfaceLight}, Dark={StaticResource ColorBgSurfaceDark}}">
                            <VerticalStackLayout Spacing="10">
                                   <Label Text="Account" FontSize="18" FontAttributes="Bold" />
                                   <Label Text="Additional options can be layered in later without changing the simplified visual system."
                                             TextColor="{AppThemeBinding Light={StaticResource ColorTextMutedLight}, Dark={StaticResource ColorTextMutedDark}}" />
                                   <Button Text="Log Out"
                                                 Margin="0,8,0,0"
                                                 Clicked="OnLogoutClicked" />
                            </VerticalStackLayout>
                     </Border>
              </VerticalStackLayout>
       </ScrollView>
</ContentPage>
