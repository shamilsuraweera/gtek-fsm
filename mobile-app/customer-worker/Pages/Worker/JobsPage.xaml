<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GTEK.FSM.MobileApp.Pages.Worker.JobsPage"
             Title="Jobs">
       <Grid Padding="20,18,20,24" RowDefinitions="Auto,Auto,*" RowSpacing="12">
              <Label Text="Jobs Workspace" FontSize="28" FontAttributes="Bold" />
              <Label Grid.Row="1"
                        Text="Accept assignments, inspect job details, and publish field status updates."
                        TextColor="{AppThemeBinding Light={StaticResource ColorTextMutedLight}, Dark={StaticResource ColorTextMutedDark}}" />

              <ScrollView Grid.Row="2">
                     <VerticalStackLayout Spacing="12">
                            <Border StrokeShape="RoundRectangle 18" Padding="12" BackgroundColor="{AppThemeBinding Light={StaticResource ColorBgSurfaceLight}, Dark={StaticResource ColorBgSurfaceDark}}">
                                   <CollectionView x:Name="JobsCollectionView"
                                                               SelectionMode="Single"
                                                               SelectionChanged="OnJobSelectionChanged"
                                                               HeightRequest="240">
                                          <CollectionView.ItemTemplate>
                                                 <DataTemplate>
                                                        <Border StrokeShape="RoundRectangle 14" Padding="12" Margin="0,0,0,8" BackgroundColor="{AppThemeBinding Light={StaticResource ColorBgSurfaceLight}, Dark={StaticResource ColorBgSurfaceDark}}">
                                                               <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto" RowSpacing="4">
                                                                      <Label Text="{Binding Title}" FontAttributes="Bold" />
                                                                      <Label Grid.Column="1"
                                                                                Text="{Binding PriorityLabel}"
                                                                                TextColor="{Binding PriorityColor}"
                                                                                FontSize="12"
                                                                                FontAttributes="Bold" />
                                                                      <Label Grid.Row="1" Text="{Binding Location}" />
                                                                      <Label Grid.Row="2" Text="{Binding StatusLabel}" TextColor="{Binding StatusColor}" FontAttributes="Bold" FontSize="12" />
                                                               </Grid>
                                                        </Border>
                                                 </DataTemplate>
                                          </CollectionView.ItemTemplate>
                                   </CollectionView>
                            </Border>

                            <Border StrokeShape="RoundRectangle 18" Padding="16" BackgroundColor="{AppThemeBinding Light={StaticResource ColorBgSurfaceLight}, Dark={StaticResource ColorBgSurfaceDark}}">
                                   <VerticalStackLayout Spacing="8">
                                          <Label Text="Job Detail" FontSize="18" FontAttributes="Bold" />
                                          <Label x:Name="SelectedJobTitleLabel" FontSize="16" FontAttributes="Bold" />
                                          <Label x:Name="SelectedJobDescriptionLabel" TextColor="{AppThemeBinding Light={StaticResource ColorTextMutedLight}, Dark={StaticResource ColorTextMutedDark}}" />
                                          <Label x:Name="SelectedJobMetaLabel" FontSize="12" />

                                          <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                                 <Button x:Name="AcceptAssignmentButton" Text="Accept Assignment" Clicked="OnAcceptAssignmentClicked" />
                                                 <Button Grid.Column="1" Text="Refresh Detail" Clicked="OnRefreshDetailClicked" />
                                          </Grid>

                                            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                                                  <Button Text="Start Work"
                                                         FontSize="12"
                                                         Padding="8,6"
                                                         Clicked="OnStartWorkClicked" />
                                                  <Button Grid.Column="1"
                                                         Text="Place On Hold"
                                                         FontSize="12"
                                                         Padding="8,6"
                                                         Clicked="OnPlaceOnHoldClicked" />
                                                  <Button Grid.Column="2"
                                                         Text="Complete"
                                                         FontSize="12"
                                                         Padding="8,6"
                                                         Clicked="OnCompleteRequestClicked" />
                                            </Grid>

                                          <Button Text="Resume Work" FontSize="12" Padding="8,6" Clicked="OnResumeWorkClicked" />

                                          <Label Text="Status Update" FontSize="15" FontAttributes="Bold" Margin="0,4,0,0" />
                                          <Picker x:Name="StatusPicker" Title="Select request status" />
                                          <Button Text="Publish Request Status" Clicked="OnPublishStatusClicked" />
                                          <Label x:Name="StatusResultLabel" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource ColorTextMutedLight}, Dark={StaticResource ColorTextMutedDark}}" />

                                          <Label Text="Worker Feedback" FontSize="15" FontAttributes="Bold" Margin="0,6,0,0" />
                                          <Label x:Name="WorkerFeedbackHintLabel"
                                                 FontSize="12"
                                                 TextColor="{AppThemeBinding Light={StaticResource ColorTextMutedLight}, Dark={StaticResource ColorTextMutedDark}}" />
                                          <Picker x:Name="WorkerFeedbackTypePicker" Title="Select feedback category" />
                                          <Picker x:Name="WorkerRatingPicker" Title="Select rating" />
                                          <Editor x:Name="WorkerFeedbackCommentEditor"
                                                  Placeholder="Describe blockers, quality observations, or follow-up issues"
                                                  AutoSize="TextChanges"
                                                  MaxLength="1000"
                                                  HeightRequest="90" />
                                          <Button x:Name="SubmitWorkerFeedbackButton"
                                                  Text="Submit Worker Feedback"
                                                  Clicked="OnSubmitWorkerFeedbackClicked" />
                                          <Label x:Name="WorkerFeedbackStatusLabel"
                                                 FontSize="12"
                                                 TextColor="{AppThemeBinding Light={StaticResource ColorTextMutedLight}, Dark={StaticResource ColorTextMutedDark}}" />
                                   </VerticalStackLayout>
                            </Border>
                     </VerticalStackLayout>
              </ScrollView>
       </Grid>
</ContentPage>
