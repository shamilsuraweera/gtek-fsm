<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GTEK.FSM.MobileApp.Pages.Worker.JobsPage"
             Title="Jobs">
       <Grid Padding="16" RowDefinitions="Auto,Auto,*" RowSpacing="12">
              <Label Text="Jobs Workspace" FontSize="24" FontAttributes="Bold" />
              <Label Grid.Row="1"
                        Text="Accept assignments, inspect job details, and publish field status updates."
                        TextColor="{AppThemeBinding Light=#5F6B79, Dark=#A3B0C0}" />

              <ScrollView Grid.Row="2">
                     <VerticalStackLayout Spacing="12">
                            <Border StrokeShape="RoundRectangle 12" Padding="10" BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#18202C}">
                                   <CollectionView x:Name="JobsCollectionView"
                                                               SelectionMode="Single"
                                                               SelectionChanged="OnJobSelectionChanged"
                                                               HeightRequest="240">
                                          <CollectionView.ItemTemplate>
                                                 <DataTemplate>
                                                        <Border StrokeShape="RoundRectangle 10" Padding="10" Margin="0,0,0,8" BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#111827}">
                                                               <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto" RowSpacing="4">
                                                                      <Label Text="{Binding Title}" FontAttributes="Bold" />
                                                                      <Label Grid.Column="1"
                                                                                Text="{Binding PriorityLabel}"
                                                                                TextColor="{Binding PriorityColor}"
                                                                                FontSize="12"
                                                                                FontAttributes="Bold" />
                                                                      <Label Grid.Row="1" Text="{Binding Location}" />
                                                                      <Label Grid.Row="2" Text="{Binding StatusLabel}" TextColor="{Binding StatusColor}" FontAttributes="Bold" FontSize="12" />
                                                               </Grid>
                                                        </Border>
                                                 </DataTemplate>
                                          </CollectionView.ItemTemplate>
                                   </CollectionView>
                            </Border>

                            <Border StrokeShape="RoundRectangle 12" Padding="12" BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#18202C}">
                                   <VerticalStackLayout Spacing="8">
                                          <Label Text="Job Detail" FontSize="18" FontAttributes="Bold" />
                                          <Label x:Name="SelectedJobTitleLabel" FontSize="16" FontAttributes="Bold" />
                                          <Label x:Name="SelectedJobDescriptionLabel" TextColor="{AppThemeBinding Light=#5F6B79, Dark=#A3B0C0}" />
                                          <Label x:Name="SelectedJobMetaLabel" FontSize="12" />

                                          <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                                 <Button x:Name="AcceptAssignmentButton" Text="Accept Assignment" Clicked="OnAcceptAssignmentClicked" />
                                                 <Button Grid.Column="1" Text="Open Map" Clicked="OnOpenMapClicked" />
                                          </Grid>

                                            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                                                  <Button Text="Start Travel"
                                                         FontSize="12"
                                                         Padding="8,6"
                                                         Clicked="OnStartTravelClicked" />
                                                  <Button Grid.Column="1"
                                                         Text="Mark On-Site"
                                                         FontSize="12"
                                                         Padding="8,6"
                                                         Clicked="OnMarkOnSiteClicked" />
                                                  <Button Grid.Column="2"
                                                         Text="Complete"
                                                         FontSize="12"
                                                         Padding="8,6"
                                                         Clicked="OnCompleteJobClicked" />
                                            </Grid>

                                          <Label Text="Status Update" FontSize="15" FontAttributes="Bold" Margin="0,4,0,0" />
                                          <Picker x:Name="StatusPicker" Title="Select new status" />
                                          <Button Text="Publish Status" Clicked="OnPublishStatusClicked" />
                                          <Label x:Name="StatusResultLabel" FontSize="12" TextColor="{AppThemeBinding Light=#166534, Dark=#86EFAC}" />
                                   </VerticalStackLayout>
                            </Border>
                     </VerticalStackLayout>
              </ScrollView>
       </Grid>
</ContentPage>
