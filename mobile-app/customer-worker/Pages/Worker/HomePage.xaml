<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GTEK.FSM.MobileApp.Pages.Worker.HomePage"
             Title="Home">
       <ScrollView>
              <VerticalStackLayout Padding="20,18,20,28" Spacing="16">
                     <VerticalStackLayout Spacing="4">
                            <Label Text="Worker Dispatch" FontSize="28" FontAttributes="Bold" />
                            <Label Text="Review available jobs, accept assignments, and update field status fast."
                                   TextColor="{AppThemeBinding Light={StaticResource ColorTextMutedLight}, Dark={StaticResource ColorTextMutedDark}}" />
                     </VerticalStackLayout>

                     <Border StrokeShape="RoundRectangle 20" Padding="18" BackgroundColor="{AppThemeBinding Light={StaticResource ColorBgSurfaceLight}, Dark={StaticResource ColorBgSurfaceDark}}">
                            <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto" RowSpacing="4">
                                   <Label Text="Field overview" FontSize="20" FontAttributes="Bold" />
                                   <Border Grid.Column="1"
                                           StrokeThickness="0"
                                           BackgroundColor="{AppThemeBinding Light=#EFFAF4, Dark=#365F4A}"
                                           Padding="10,4"
                                           VerticalOptions="Start">
                                          <Label Text="ONLINE" FontSize="11" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#166534, Dark=#86EFAC}" />
                                   </Border>
                                   <Label Grid.Row="1"
                                          Text="The clean layout keeps route and execution decisions visible at a glance."
                                          TextColor="{AppThemeBinding Light={StaticResource ColorTextMutedLight}, Dark={StaticResource ColorTextMutedDark}}" />
                            </Grid>
                     </Border>

                     <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                            <Border StrokeShape="RoundRectangle 18" Padding="16" BackgroundColor="{AppThemeBinding Light={StaticResource ColorBgSurfaceLight}, Dark={StaticResource ColorBgSurfaceDark}}">
                                   <VerticalStackLayout Spacing="4">
                                          <Label Text="Available" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource ColorTextMutedLight}, Dark={StaticResource ColorTextMutedDark}}" />
                                          <Label Text="5" FontSize="30" FontAttributes="Bold" />
                                          <Label Text="2 high priority" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource ColorAccentLight}, Dark={StaticResource ColorAccentDark}}" />
                                   </VerticalStackLayout>
                            </Border>
                            <Border Grid.Column="1" StrokeShape="RoundRectangle 18" Padding="16" BackgroundColor="{AppThemeBinding Light={StaticResource ColorBgSurfaceLight}, Dark={StaticResource ColorBgSurfaceDark}}">
                                   <VerticalStackLayout Spacing="4">
                                          <Label Text="Assigned" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource ColorTextMutedLight}, Dark={StaticResource ColorTextMutedDark}}" />
                                          <Label Text="3" FontSize="30" FontAttributes="Bold" />
                                          <Label Text="1 in progress" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource ColorAccentLight}, Dark={StaticResource ColorAccentDark}}" />
                                   </VerticalStackLayout>
                            </Border>
                     </Grid>

                     <Border StrokeShape="RoundRectangle 18" Padding="16" BackgroundColor="{AppThemeBinding Light={StaticResource ColorBgSurfaceLight}, Dark={StaticResource ColorBgSurfaceDark}}">
                            <VerticalStackLayout Spacing="8">
                                   <Label Text="Shift Notes" FontSize="18" FontAttributes="Bold" />
                                   <Label Text="Job #JOB-884 requires access card at reception." />
                                   <Label Text="Downtown route has heavy traffic after 3 PM." />
                                   <Label Text="Safety check required before generator startup tasks." />
                            </VerticalStackLayout>
                     </Border>

                     <Border StrokeShape="RoundRectangle 18" Padding="16" BackgroundColor="{AppThemeBinding Light={StaticResource ColorBgSurfaceLight}, Dark={StaticResource ColorBgSurfaceDark}}">
                            <VerticalStackLayout Spacing="8">
                                   <Label Text="Quick Actions" FontSize="18" FontAttributes="Bold" />
                                   <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                                          <Button Text="Accept Top"
                                                  FontSize="12"
                                                  Padding="8,6"
                                                  Clicked="OnAcceptTopJobClicked" />
                                          <Button Grid.Column="1"
                                                  Text="Update Status"
                                                  FontSize="12"
                                                  Padding="8,6"
                                                  Clicked="OnUpdateStatusClicked" />
                                          <Button Grid.Column="2"
                                                  Text="Call Dispatch"
                                                  FontSize="12"
                                                  Padding="8,6"
                                                  Clicked="OnCallDispatchClicked" />
                                   </Grid>
                            </VerticalStackLayout>
                     </Border>

                     <Button Text="Open Jobs Workspace" Margin="0,4,0,0" Clicked="OnOpenJobsWorkspaceClicked" />
              </VerticalStackLayout>
       </ScrollView>
</ContentPage>
