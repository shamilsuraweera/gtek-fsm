<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GTEK.FSM.MobileApp.Pages.Worker.HomePage"
             Title="Home">
       <ScrollView>
              <VerticalStackLayout Padding="16" Spacing="14">
                     <Border StrokeShape="RoundRectangle 14" Padding="14" BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#18202C}">
                            <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto" RowSpacing="4">
                                   <Label Text="Worker Dispatch" FontSize="22" FontAttributes="Bold" />
                                   <Label Grid.Row="1"
                                             Text="Review available jobs, accept assignments, and update field status fast."
                                             TextColor="{AppThemeBinding Light=#5F6B79, Dark=#A3B0C0}" />
                                   <Label Grid.Column="1" Text="ONLINE" FontSize="12" TextColor="{AppThemeBinding Light=#166534, Dark=#86EFAC}" />
                            </Grid>
                     </Border>

                     <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                            <Border StrokeShape="RoundRectangle 12" Padding="12" BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#18202C}">
                                   <VerticalStackLayout Spacing="4">
                                          <Label Text="Available" FontSize="12" TextColor="{AppThemeBinding Light=#5F6B79, Dark=#A3B0C0}" />
                                          <Label Text="5" FontSize="26" FontAttributes="Bold" />
                                          <Label Text="2 high priority" FontSize="12" TextColor="{AppThemeBinding Light=#B45309, Dark=#FBBF24}" />
                                   </VerticalStackLayout>
                            </Border>
                            <Border Grid.Column="1" StrokeShape="RoundRectangle 12" Padding="12" BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#18202C}">
                                   <VerticalStackLayout Spacing="4">
                                          <Label Text="Assigned" FontSize="12" TextColor="{AppThemeBinding Light=#5F6B79, Dark=#A3B0C0}" />
                                          <Label Text="3" FontSize="26" FontAttributes="Bold" />
                                          <Label Text="1 in progress" FontSize="12" TextColor="{AppThemeBinding Light=#0F6ABD, Dark=#71B0FF}" />
                                   </VerticalStackLayout>
                            </Border>
                     </Grid>

                     <Border StrokeShape="RoundRectangle 12" Padding="12" BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#18202C}">
                            <VerticalStackLayout Spacing="8">
                                   <Label Text="Shift Notes" FontSize="16" FontAttributes="Bold" />
                                   <Label Text="• Job #JOB-884 requires access card at reception." />
                                   <Label Text="• Downtown route has heavy traffic after 3 PM." />
                                   <Label Text="• Safety check required before generator startup tasks." />
                            </VerticalStackLayout>
                     </Border>

                     <Button Text="Open Jobs Workspace" Clicked="OnOpenJobsWorkspaceClicked" />
              </VerticalStackLayout>
       </ScrollView>
</ContentPage>
