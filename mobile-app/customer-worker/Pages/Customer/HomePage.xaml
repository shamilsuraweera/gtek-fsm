<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GTEK.FSM.MobileApp.Pages.Customer.HomePage"
             Title="Home">
       <ScrollView>
              <VerticalStackLayout Padding="16" Spacing="16">
                     <Border StrokeShape="RoundRectangle 14" Padding="14" BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#18202C}">
                            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="4">
                                   <Label Text="Customer Dashboard" FontSize="22" FontAttributes="Bold" />
                                   <Label Grid.Row="1" Text="Track requests, active jobs, and account updates from one place."
                                             TextColor="{AppThemeBinding Light=#5F6B79, Dark=#A3B0C0}" />
                                   <Label Grid.Column="1" Text="LIVE"
                                             FontSize="12"
                                             TextColor="{AppThemeBinding Light=#0F6ABD, Dark=#71B0FF}"
                                             VerticalOptions="Start" />
                            </Grid>
                     </Border>

                     <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                            <Border StrokeShape="RoundRectangle 12" Padding="12" BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#18202C}">
                                   <VerticalStackLayout Spacing="4">
                                          <Label Text="Open Requests" FontSize="12" TextColor="{AppThemeBinding Light=#5F6B79, Dark=#A3B0C0}" />
                                          <Label Text="3" FontSize="26" FontAttributes="Bold" />
                                          <Label Text="1 delayed" FontSize="12" TextColor="{AppThemeBinding Light=#B45309, Dark=#FBBF24}" />
                                   </VerticalStackLayout>
                            </Border>

                            <Border Grid.Column="1" StrokeShape="RoundRectangle 12" Padding="12" BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#18202C}">
                                   <VerticalStackLayout Spacing="4">
                                          <Label Text="Active Jobs" FontSize="12" TextColor="{AppThemeBinding Light=#5F6B79, Dark=#A3B0C0}" />
                                          <Label Text="2" FontSize="26" FontAttributes="Bold" />
                                          <Label Text="Next ETA 2:30 PM" FontSize="12" TextColor="{AppThemeBinding Light=#166534, Dark=#86EFAC}" />
                                   </VerticalStackLayout>
                            </Border>
                     </Grid>

                     <Border StrokeShape="RoundRectangle 12" Padding="12" BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#18202C}">
                            <VerticalStackLayout Spacing="8">
                                   <Label Text="Today" FontSize="16" FontAttributes="Bold" />
                                   <Label Text="• Technician check-in window: 2:00 PM - 4:00 PM" />
                                   <Label Text="• Pending approval: Quote for rooftop unit service" />
                                   <Label Text="• Profile reminder: verify emergency contact" />
                            </VerticalStackLayout>
                     </Border>

                     <Border StrokeShape="RoundRectangle 12" Padding="12" BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#18202C}">
                            <VerticalStackLayout Spacing="8">
                                   <Label Text="Quick Actions" FontSize="16" FontAttributes="Bold" />
                                   <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                                          <Button Text="Track Job"
                                                  FontSize="12"
                                                  Padding="8,6"
                                                  Clicked="OnTrackActiveJobClicked" />
                                          <Button Grid.Column="1"
                                                  Text="Approve Quote"
                                                  FontSize="12"
                                                  Padding="8,6"
                                                  Clicked="OnApproveQuoteClicked" />
                                          <Button Grid.Column="2"
                                                  Text="Contact Support"
                                                  FontSize="12"
                                                  Padding="8,6"
                                                  Clicked="OnContactSupportClicked" />
                                   </Grid>
                            </VerticalStackLayout>
                     </Border>

                     <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                            <Button Text="View Requests" Clicked="OnViewRequestsClicked" />
                            <Button Grid.Column="1" Text="Edit Profile" Clicked="OnEditProfileClicked" />
                     </Grid>
              </VerticalStackLayout>
       </ScrollView>
</ContentPage>
