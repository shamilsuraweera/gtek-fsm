<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GTEK.FSM.MobileApp.Pages.Customer.RequestsPage"
             Title="Requests">
       <Grid Padding="16" RowDefinitions="Auto,Auto,*" RowSpacing="12">
              <Label Text="Request Center" FontSize="24" FontAttributes="Bold" />
              <Label Grid.Row="1"
                        Text="Select a request to inspect details and live stage progression."
                        TextColor="{AppThemeBinding Light=#5F6B79, Dark=#A3B0C0}" />

              <ScrollView Grid.Row="2">
                     <VerticalStackLayout Spacing="12">
                            <Border StrokeShape="RoundRectangle 12" Padding="12" BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#18202C}">
                                   <VerticalStackLayout Spacing="8">
                                          <Label Text="Create New Request" FontSize="18" FontAttributes="Bold" />
                                          <Label Text="Choose a category and describe the issue so dispatch can route it quickly."
                                                 FontSize="12"
                                                 TextColor="{AppThemeBinding Light=#5F6B79, Dark=#A3B0C0}" />

                                          <Label Text="Category" FontAttributes="Bold" FontSize="13" />
                                          <Picker x:Name="CategoryPicker"
                                                  Title="Select category"
                                                  ItemDisplayBinding="{Binding Name}" />

                                          <Label Text="Details" FontAttributes="Bold" FontSize="13" />
                                          <Editor x:Name="RequestDetailsEditor"
                                                  Placeholder="Describe the issue in at least 10 characters"
                                                  AutoSize="TextChanges"
                                                  MaxLength="150"
                                                  HeightRequest="100" />

                                          <Label x:Name="CreateRequestFeedbackLabel"
                                                 FontSize="12"
                                                 TextColor="{AppThemeBinding Light=#B42318, Dark=#FCA5A5}" />

                                          <Button Text="Submit Request"
                                                  Clicked="OnSubmitRequestClicked" />
                                   </VerticalStackLayout>
                            </Border>

                            <Border StrokeShape="RoundRectangle 12" Padding="10" BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#18202C}">
                                   <CollectionView x:Name="RequestsCollectionView"
                                                               SelectionMode="Single"
                                                               SelectionChanged="OnRequestSelectionChanged"
                                                               HeightRequest="240">
                                          <CollectionView.ItemTemplate>
                                                 <DataTemplate>
                                                        <Border StrokeShape="RoundRectangle 10" Padding="10" Margin="0,0,0,8" BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#111827}">
                                                               <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto" RowSpacing="4">
                                                                      <Label Text="{Binding Title}" FontAttributes="Bold" />
                                                                      <Label Grid.Column="1"
                                                                                Text="{Binding StatusLabel}"
                                                                                TextColor="{Binding StatusColor}"
                                                                                FontAttributes="Bold"
                                                                                FontSize="12" />
                                                                      <Label Grid.Row="1" Text="{Binding Summary}" TextColor="{AppThemeBinding Light=#5F6B79, Dark=#A3B0C0}" />
                                                                      <Label Grid.Row="2" Text="{Binding EtaText}" FontSize="12" />
                                                               </Grid>
                                                        </Border>
                                                 </DataTemplate>
                                          </CollectionView.ItemTemplate>
                                   </CollectionView>
                            </Border>

                            <Border StrokeShape="RoundRectangle 12" Padding="12" BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#18202C}">
                                   <VerticalStackLayout Spacing="8">
                                          <Label Text="Request Detail" FontSize="18" FontAttributes="Bold" />
                                          <Label x:Name="SelectedRequestTitleLabel" FontSize="16" FontAttributes="Bold" />
                                          <Label x:Name="SelectedRequestDescriptionLabel"
                                                    TextColor="{AppThemeBinding Light=#5F6B79, Dark=#A3B0C0}" />
                                          <Label x:Name="SelectedRequestMetaLabel" FontSize="12" />
                                          <Label x:Name="SelectedRequestLifecycleLabel" FontSize="12" FontAttributes="Bold" />
                                          <Label x:Name="SelectedRequestWorkerLabel" FontSize="12" />
                                          <Label x:Name="SelectedRequestJobLabel" FontSize="12" />
                                          <Label x:Name="SelectedRequestUpdatedLabel" FontSize="12"
                                                 TextColor="{AppThemeBinding Light=#5F6B79, Dark=#A3B0C0}" />

                                            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                                                  <Button Text="Escalate"
                                                         FontSize="12"
                                                         Padding="8,6"
                                                         Clicked="OnEscalateRequestClicked" />
                                                  <Button Grid.Column="1"
                                                         Text="Refresh ETA"
                                                         FontSize="12"
                                                         Padding="8,6"
                                                         Clicked="OnRefreshEtaClicked" />
                                                  <Button Grid.Column="2"
                                                         Text="Message Tech"
                                                         FontSize="12"
                                                         Padding="8,6"
                                                         Clicked="OnMessageTechnicianClicked" />
                                            </Grid>

                                          <Label Text="Status Tracking" FontSize="15" FontAttributes="Bold" Margin="0,6,0,0" />
                                          <VerticalStackLayout x:Name="StatusTimelineLayout" Spacing="6" />

                                          <Label Text="Activity Timeline" FontSize="15" FontAttributes="Bold" Margin="0,8,0,0" />
                                          <VerticalStackLayout x:Name="RequestTimelineLayout" Spacing="6" />
                                   </VerticalStackLayout>
                            </Border>
                     </VerticalStackLayout>
              </ScrollView>
       </Grid>
</ContentPage>
