# GTEK FSM Environment Configuration Template
# Copy this file to .env and adjust values for your environment.
# NEVER commit .env to version control (see .gitignore)

# ═══════════════════════════════════════════════════════════
# ENVIRONMENT SELECTION
# ═══════════════════════════════════════════════════════════
# Options: Development, Production, Local
ASPNETCORE_ENVIRONMENT=Development

# ═══════════════════════════════════════════════════════════
# DATABASE (SQL SERVER)
# ═══════════════════════════════════════════════════════════
# For Docker: Use service name 'sqlserver' instead of localhost
# For local Windows: Use . or (localdb)\\mssqllocaldb
# For local Linux/Mac: Docker is required

# SQL Server Admin Password (minimum 8 chars, 1 uppercase, 1 digit, 1 special)
SA_PASSWORD=YourStrong!Passw0rd

# Database connection parameters
SQL_SERVER_HOST=sqlserver
SQL_SERVER_PORT=1433
SQL_DATABASE=GTEK_FSM_Local
SQL_DATABASE_USER=sa
# SQL_DATABASE_PASSWORD is derived from SA_PASSWORD in docker-compose.yml

# ═══════════════════════════════════════════════════════════
# API & WEB SERVICES
# ═══════════════════════════════════════════════════════════
API_HOST=localhost
API_PORT=5000
API_SCHEME=http

WEB_PORTAL_HOST=localhost
WEB_PORTAL_PORT=5001
WEB_PORTAL_SCHEME=http

# ═══════════════════════════════════════════════════════════
# MOBILE APP (Phase 6)
# ═══════════════════════════════════════════════════════════
# If set to 1, run-mobile-app.sh also starts backend dependencies via compose.
MOBILE_ENSURE_BACKEND=0

# Optional mobile API endpoint overrides
# If GTEK_FSM_API_BASE_URL is set, it takes precedence over all defaults.
GTEK_FSM_API_BASE_URL=

# Optional debug port override (default is 5000)
GTEK_FSM_API_PORT=5000

# Optional JWT token for mobile authenticated API probe (Phase 6.3.1)
GTEK_FSM_IDENTITY_TOKEN=

# Android SDK location (set for Linux/mobile development)
# Example: /home/<user>/Android/Sdk
ANDROID_SDK_ROOT=
ANDROID_HOME=

# ═══════════════════════════════════════════════════════════
# DOCKER COMPOSE
# ═══════════════════════════════════════════════════════════
COMPOSE_PROJECT_NAME=gtek-fsm-dev
DOCKER_BUILDKIT=1

# ═══════════════════════════════════════════════════════════
# FEATURE FLAGS (Phase 0: All disabled)
# Set to 'true' to enable after implementation
# ═══════════════════════════════════════════════════════════
FEATURE_REALTIME_PIPELINE=false
FEATURE_STORAGE=false
FEATURE_EXTERNAL_NOTIFICATIONS=false
FEATURE_EXTERNAL_MAPS=false
FEATURE_PAYMENTS=false

# ═══════════════════════════════════════════════════════════
# SIGNALR (Real-time Communication - Phase 4)
# ═══════════════════════════════════════════════════════════
SIGNALR_ENABLED=false
SIGNALR_HUB_PATH=/hubs/pipeline
SIGNALR_CLIENT_TIMEOUT_SECONDS=30
SIGNALR_HANDSHAKE_TIMEOUT_SECONDS=15
SIGNALR_ENABLE_DETAILED_ERRORS=false

# ═══════════════════════════════════════════════════════════
# STORAGE (Phase 4: Select provider)
# ═══════════════════════════════════════════════════════════
STORAGE_PROVIDER=Local
STORAGE_LOCAL_ROOT_PATH=./storage

# Azure Blob Storage (when STORAGE_PROVIDER=Blob)
# STORAGE_BLOB_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net
# STORAGE_BLOB_CONTAINER_NAME=gtek-fsm

# AWS S3 (when STORAGE_PROVIDER=S3)
# STORAGE_S3_SERVICE_URL=https://s3.amazonaws.com
# STORAGE_S3_BUCKET_NAME=gtek-fsm
# STORAGE_S3_ACCESS_KEY=YOUR_AWS_ACCESS_KEY
# STORAGE_S3_SECRET_KEY=YOUR_AWS_SECRET_KEY
# STORAGE_S3_REGION=us-east-1

# ═══════════════════════════════════════════════════════════
# EXTERNAL SERVICES (Phase 3+: Enable as needed)
# ═══════════════════════════════════════════════════════════

# Notifications Service (SMS/Email)
NOTIFICATIONS_ENABLED=false
NOTIFICATIONS_PROVIDER=None
NOTIFICATIONS_BASE_URL=
NOTIFICATIONS_API_KEY=

# Maps Service (Geolocation/Routing)
MAPS_ENABLED=false
MAPS_PROVIDER=None
MAPS_BASE_URL=
MAPS_API_KEY=

# Payments Service (Stripe/PayPal)
PAYMENTS_ENABLED=false
PAYMENTS_PROVIDER=None
PAYMENTS_BASE_URL=
PAYMENTS_API_KEY=
PAYMENTS_WEBHOOK_SECRET=

# Webhooks (Incoming service callbacks)
WEBHOOKS_SIGNATURE_HEADER=X-Signature
WEBHOOKS_SIGNING_SECRET=

# ═══════════════════════════════════════════════════════════
# LOGGING
# ═══════════════════════════════════════════════════════════
LOGGING_LEVEL=Information
LOGGING_ASPNETCORE_LEVEL=Warning

# ═══════════════════════════════════════════════════════════
# SECURITY & SECRETS (Phase 2)
# ═══════════════════════════════════════════════════════════
# JWT/OAuth secrets, keys, etc. populated by Key Vault in production
# In local dev, these can be empty (defaults used)
JWT_SECRET_KEY=
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
