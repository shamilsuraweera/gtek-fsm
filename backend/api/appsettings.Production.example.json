{
  "Authentication": {
    "Jwt": {
      "Issuer": "",
      "Audience": "",
      "SigningKey": ""
    }
  },
  "Database": {
    "ConnectionString": ""
  },
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft": "Error",
      "Microsoft.AspNetCore": "Error",
