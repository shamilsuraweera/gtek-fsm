    "Payments": {
      "Enabled": false,
      "Provider": "None"
    },
    "Webhooks": {
      "SignatureHeader": "X-Signature"
    }
  },
  "Features": {
    "RealtimePipeline": {
      "Enabled": false
    },
    "Storage": {
      "Enabled": false
    },
    "ExternalNotifications": {
      "Enabled": false
