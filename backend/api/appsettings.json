{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Authentication": {
    "Jwt": {
      "Issuer": "",
      "Audience": "",
      "SigningKey": ""
    }
  },
  "Tenancy": {
    "RequireTenantResolution": true,
    "HeaderName": "X-Tenant-Id",
    "HeaderFallbackAllowedRoles": ["Admin"]
  },
  "Database": {
    "ConnectionString": ""
  },
  "SignalR": {
    "HubPath": "/hubs/pipeline",
    "EnableDetailedErrors": false,
    "ClientTimeoutSeconds": 30,
    "HandshakeTimeoutSeconds": 15
  },
  "Storage": {
    "DefaultProvider": "Local",
    "Local": {
      "RootPath": "./storage"
    },
    "Blob": {
      "ConnectionString": "",
      "ContainerName": ""
    },
    "S3": {
      "ServiceUrl": "",
      "BucketName": "",
      "AccessKey": "",
      "SecretKey": "",
      "Region": ""
    }
  },
  "ExternalServices": {
    "Notifications": {
      "Enabled": false,
      "Provider": "None",
      "BaseUrl": "",
      "ApiKey": ""
    },
    "Maps": {
      "Enabled": false,
      "Provider": "None",
      "BaseUrl": "",
      "ApiKey": ""
    },
    "Payments": {
      "Enabled": false,
      "Provider": "None",
      "BaseUrl": "",
      "ApiKey": "",
      "WebhookSecret": ""
    },
    "Webhooks": {
      "Enabled": false,
      "SignatureHeader": "X-Signature",
      "SigningSecret": ""
    }
  },
  "Features": {
    "RealtimePipeline": {
      "Enabled": false
    },
    "Storage": {
      "Enabled": false
    },
    "ExternalNotifications": {
      "Enabled": false
    },
    "ExternalMaps": {
      "Enabled": false
    },
    "Payments": {
      "Enabled": false
    }
  },
  "Automation": {
    "Enabled": false,
    "IntervalSeconds": 300,
    "ReminderCooldownHours": 24,
    "SubscriptionExpiryReminderDays": 14,
    "MaxActionsPerTenantPerRun": 10,
    "EnableSlaReminderWorkflow": true,
    "EnableSubscriptionExpiryReminderWorkflow": true
  },
  "AllowedHosts": "*"
}
