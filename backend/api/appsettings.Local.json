{
  "Authentication": {
    "Jwt": {
      "Issuer": "GTEK.FSM.Local",
      "Audience": "GTEK.FSM.Clients",
      "SigningKey": "local-only-signing-key-change-me-32chars-min"
    }
  },
  "ConnectionStrings": {
    "MainDb": "Server=localhost;Database=GTEK_FSM;Trusted_Connection=True;TrustServerCertificate=True"
  },
  "SignalR": {
    "HubPath": "/hubs/pipeline"
  },
  "Tenancy": {
    "DefaultTenantId": "00000000-0000-0000-0000-000000000001",
    "RequireTenantResolution": true,
    "HeaderName": "X-Tenant-Id",
    "HeaderFallbackAllowedRoles": ["Admin"]
  },
  "Features": {
    "RealtimePipeline": {
      "Enabled": true
    }
  }
}
