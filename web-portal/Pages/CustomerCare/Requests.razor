@page "/customer-care/requests"

@using GTEK.FSM.WebPortal.Components
@using GTEK.FSM.WebPortal.Models
@using GTEK.FSM.WebPortal.Services

@inject ResilientDataFetcher Fetcher

<PageTitle>Customer Care Requests</PageTitle>

<h1>Customer Care Requests</h1>

<ResilienceErrorBoundary @ref="errorBoundary">
	<DataFetchStateDisplay
		State="@fetchState.State"
		LoadingMessage="Fetching request queue..."
		ErrorMessage="@fetchState.ErrorMessage"
		StaleMessage="Request queue is cached; newer updates may be available."
		PartialMessage="Loaded request queue (some items may be incomplete)."
		RetryingMessage="@($"Retrying request queue... Attempt {fetchState.RetryAttempts}")"
		AllowStaleRender="true"
		OnRetry="@HandleRetry"
		OnDismiss="@HandleDismiss">
		<OperationalQueueListWithControls
			Title="Customer Care Request Queue"
			StickyContext="Live queue with triage controls, status signals, and workload prioritization"
			Items="@(fetchState.Data ?? [])"
			OnActionTriggered="@HandleTriageAction" />
	</DataFetchStateDisplay>
</ResilienceErrorBoundary>

@code {
	private ResilienceErrorBoundary? errorBoundary;
	private FetchResult<List<OperationalQueueItem>> fetchState = new();

	protected override async Task OnInitializedAsync()
	{
		await FetchQueueData();
	}

	private async Task FetchQueueData()
	{
		try
		{
			fetchState = await Fetcher.FetchAsync(
				async () =>
				{
					// Simulate network delay
					await Task.Delay(300);
					return GenerateSampleQueueItems().ToList();
				},
				fetchState,
				maxRetries: 2,
				staleThresholdSeconds: 60);
		}
		catch (Exception ex)
		{
			errorBoundary?.HandleError(ex, "Failed to fetch request queue. Please try again.");
		}
	}

	private async Task HandleRetry()
	{
		await FetchQueueData();
	}

	private void HandleDismiss()
	{
		fetchState.State = FetchState.Idle;
	}

	private async Task HandleTriageAction((OperationalQueueItem item, TriageAction action) args)
	{
		var (item, action) = args;
		try
		{
			// Simulate action processing
			await Task.Delay(200);

			// Update the item status based on action
			item.Status = action switch
			{
				TriageAction.Assign => RequestStatus.Assigned,
				TriageAction.Complete => RequestStatus.Completed,
				TriageAction.Escalate => RequestStatus.Escalated,
				TriageAction.Hold => RequestStatus.OnHold,
				TriageAction.Reopen => RequestStatus.Assessing,
				_ => item.Status,
			};

			StateHasChanged();
		}
		catch (Exception ex)
		{
			errorBoundary?.HandleError(ex, $"Failed to execute {action} action. Please try again.");
		}
		};
	}

	private List<OperationalQueueItem> GenerateSampleQueueItems()
	{
		var items = new List<OperationalQueueItem>();
		var stages = new[] { "Intake", "Assessment", "Dispatch", "In Progress" };
		var priorities = new[] { "Critical", "High", "Medium", "Low" };
		var statuses = new[] { RequestStatus.New, RequestStatus.Assessing, RequestStatus.Assigned, RequestStatus.Active };
		var urgencies = new[] { UrgencyLevel.Critical, UrgencyLevel.High, UrgencyLevel.Moderate, UrgencyLevel.Normal };
		var workers = new[] { "Alice Chen", "Bob Silva", "Carol López", "David Patel", null };

		for (int i = 1; i <= 120; i++)
		{
			var ageMinutes = i * 3;
			var urgencyLevel = urgencies[i % urgencies.Length];
			var isEscalated = i % 7 == 0;
			var isSLABreach = ageMinutes > 240 && urgencyLevel >= UrgencyLevel.High;

			items.Add(new OperationalQueueItem
			{
				Reference = $"REQ-{1000 + i}",
				Customer = $"Customer {i:000}",
				Stage = stages[i % stages.Length],
				Priority = priorities[i % priorities.Length],
				Summary = $"Operational request {i:000}: System maintenance, troubleshooting, and follow-up actions.",
				UpdatedAtUtc = DateTime.UtcNow.AddMinutes(-ageMinutes),
				Status = statuses[i % statuses.Length],
				UrgencyLevel = urgencyLevel,
				AgeMinutes = ageMinutes,
				IsEscalated = isEscalated,
				IsSLABreach = isSLABreach,
				AssignedWorker = workers[i % workers.Length],
				EstimatedMinutes = Random.Shared.Next(30, 240),
				WorkloadHint = GetWorkloadHint(urgencyLevel, isEscalated, isSLABreach),
			});
		}

		return items;
	}

	private string GetWorkloadHint(UrgencyLevel urgency, bool escalated, bool slaBreach)
	{
		if (slaBreach) return "SLA breached—immediate action required";
		if (escalated) return "Escalated—requires priority handling";
		return urgency switch
		{
			UrgencyLevel.Critical => "Critical priority—attention needed",
			UrgencyLevel.High => "High priority—queue for next available worker",
			UrgencyLevel.Moderate => "Moderate priority—standard processing",
			_ => "Normal—standard queue",
		};
	}
}
