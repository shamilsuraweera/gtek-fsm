@page "/customer-care/requests/workspace"
@page "/customer-care/requests/workspace/{RequestId:guid}"

@using GTEK.FSM.WebPortal.Components
@using GTEK.FSM.WebPortal.Models
@using GTEK.FSM.WebPortal.Services
@using GTEK.FSM.WebPortal.Services.Realtime
@using GTEK.FSM.WebPortal.Services.Requests
@using GTEK.FSM.Shared.Contracts.Api.Contracts.Feedback
@using GTEK.FSM.Shared.Contracts.Api.Contracts.Realtime

@inject NavigationManager Navigation
@inject ResilientDataFetcher Fetcher
@inject IOperationalRealtimeClient RealtimeClient
@inject IRequestWorkspaceApiClient WorkspaceApiClient

@implements IDisposable

<PageTitle>Customer Care Request Workspace</PageTitle>

<h1>Customer Care Request Workspace</h1>
<OperationalRealtimeStatusBadge State="@realtimeConnectionState" />

<ResilienceErrorBoundary @ref="errorBoundary">
    <DataFetchStateDisplay
        State="@fetchState.State"
        LoadingMessage="Opening request workspace..."
        ErrorMessage="@fetchState.ErrorMessage"
        StaleMessage="Workspace is showing cached request context."
        PartialMessage="Workspace loaded with partial context."
        RetryingMessage="@($"Retrying workspace load... Attempt {fetchState.RetryAttempts}")"
        AllowStaleRender="true"
        OnRetry="@HandleRetry"
        OnDismiss="@HandleDismiss">

        @if (ActiveItem is not null)
        {
            <section class="request-workspace-shell">
                <header class="workspace-header">
                    <div>
                        <p class="workspace-ref mono">@ActiveItem.Reference</p>
                        <h2 class="workspace-title">@ActiveItem.Summary</h2>
                        <p class="workspace-subtitle">Customer @ActiveItem.Customer · Stage @ActiveItem.Stage</p>
                    </div>
                    <div class="workspace-header-actions">
                        <button class="btn-quick-action" @onclick="GoBackToQueue">Back to queue</button>
                        <button class="btn-quick-action btn-primary" @onclick="ReloadWorkspaceAsync" disabled="@isMutating">Refresh workspace</button>
                    </div>
                </header>

                @if (!string.IsNullOrWhiteSpace(workspaceMessage))
                {
                    <div class="alert alert-success mt-3" role="status">@workspaceMessage</div>
                }

                @if (!string.IsNullOrWhiteSpace(workspaceError))
                {
                    <div class="alert alert-danger mt-3" role="alert">@workspaceError</div>
                }

                <section class="workspace-panel">
                    <h3>Status Signals</h3>
                    <StatusSignalDisplay
                        Status="@ActiveItem.Status"
                        UrgencyLevel="@ActiveItem.UrgencyLevel"
                        AgeMinutes="@ActiveItem.AgeMinutes"
                        IsEscalated="@ActiveItem.IsEscalated"
                        IsSLABreach="@ActiveItem.IsSLABreach"
                        AssignedWorker="@ActiveItem.AssignedWorker" />
                </section>

                <section class="workspace-grid">
                    <section class="workspace-panel">
                        <h3>Lifecycle Controls</h3>
                        <p class="workspace-hint">Persisted lifecycle transitions are executed directly against the request API.</p>
                        <TriageControlsPanel
                            AvailableActions="@LifecycleActions"
                            OnAction="@HandleLifecycleAction"
                            ShowMoreMenu="false"
                            IsActionDisabled="@isMutating" />
                    </section>

                    <section class="workspace-panel">
                        <h3>Assignment Controls</h3>
                        <p class="workspace-hint">Assignment endpoints are live. Enter a worker user id until the richer picker lands in the next task.</p>
                        <div class="mb-3">
                            <label class="form-label" for="worker-user-id">Worker user id</label>
                            <input id="worker-user-id" class="form-control" @bind="workerUserIdInput" @bind:event="oninput" disabled="@isMutating" />
                        </div>
                        <div class="rapid-actions-row">
                            <button class="btn-quick-action" @onclick="AssignWorkerAsync" disabled="@(!CanAssign || isMutating)">Assign</button>
                            <button class="btn-quick-action btn-warning" @onclick="ReassignWorkerAsync" disabled="@(!CanReassign || isMutating)">Reassign</button>
                        </div>
                    </section>
                </section>

                <section class="workspace-grid">
                    <section class="workspace-panel">
                        <h3>Request Context</h3>
                        <dl class="row mb-0">
                            <dt class="col-sm-4">Tenant</dt>
                            <dd class="col-sm-8 mono">@ActiveItem.TenantId</dd>
                            <dt class="col-sm-4">Customer user</dt>
                            <dd class="col-sm-8 mono">@workspaceSnapshot?.CustomerUserId</dd>
                            <dt class="col-sm-4">Created</dt>
                            <dd class="col-sm-8 mono">@workspaceSnapshot?.CreatedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</dd>
                            <dt class="col-sm-4">Updated</dt>
                            <dd class="col-sm-8 mono">@ActiveItem.UpdatedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</dd>
                        </dl>
                    </section>

                    <section class="workspace-panel">
                        <h3>Assignment Context</h3>
                        <dl class="row mb-0">
                            <dt class="col-sm-4">Active job</dt>
                            <dd class="col-sm-8 mono">@(workspaceSnapshot?.ActiveJobId ?? "No active job")</dd>
                            <dt class="col-sm-4">Job status</dt>
                            <dd class="col-sm-8">@(workspaceSnapshot?.ActiveJobStatus ?? "No assignment state")</dd>
                            <dt class="col-sm-4">Assigned worker</dt>
                            <dd class="col-sm-8 mono">@(ActiveItem.AssignedWorkerId ?? "Unassigned")</dd>
                        </dl>
                    </section>
                </section>

                <section class="workspace-panel">
                    <h3>Timeline Context</h3>
                    <ol class="workspace-timeline">
                        @foreach (var timeline in TimelineEntries)
                        {
                            <li class="workspace-timeline-item" @key="timeline.Id">
                                <span class="workspace-timeline-time mono">@timeline.Timestamp.ToLocalTime().ToString("MM-dd HH:mm")</span>
                                <span>@timeline.Message</span>
                            </li>
                        }
                    </ol>
                </section>

                <section class="workspace-panel">
                    <h3>Feedback Review</h3>
                    @if (FeedbackEntries.Count == 0)
                    {
                        <p class="workspace-hint">No feedback has been submitted for this request yet.</p>
                    }
                    else
                    {
                        <p class="workspace-hint">@FeedbackEntries.Count submission(s) recorded. Average rating: @AverageFeedbackRating.ToString("0.0")</p>
                        <ol class="workspace-timeline">
                            @foreach (var feedback in FeedbackEntries)
                            {
                                <li class="workspace-timeline-item" @key="feedback.Id">
                                    <span class="workspace-timeline-time mono">@feedback.CreatedAtUtc.ToLocalTime().ToString("MM-dd HH:mm")</span>
                                    <span>@DescribeFeedback(feedback)</span>
                                </li>
                            }
                        </ol>
                    }
                </section>
            </section>
        }
    </DataFetchStateDisplay>
</ResilienceErrorBoundary>

@code {
    [Parameter]
    public string? RequestId { get; set; }

    private static readonly IReadOnlyList<TriageAction> LifecycleActions =
    [
        TriageAction.Complete,
        TriageAction.Hold,
        TriageAction.Reopen,
        TriageAction.Reject,
    ];

    private ResilienceErrorBoundary? errorBoundary;
    private FetchResult<RequestWorkspaceSnapshot> fetchState = new();
    private RequestWorkspaceSnapshot? workspaceSnapshot;
    private IDisposable? statusSubscription;
    private IDisposable? assignmentSubscription;
    private OperationalRealtimeConnectionState realtimeConnectionState;
    private readonly List<RequestWorkspaceTimelineEntry> clientTimelineEntries = [];
    private string? loadedRequestId;
    private string workerUserIdInput = string.Empty;
    private string? workspaceMessage;
    private string? workspaceError;
    private bool isMutating;

    private OperationalQueueItem? ActiveItem => workspaceSnapshot?.Item;

    private IReadOnlyList<RequestWorkspaceTimelineEntry> TimelineEntries =>
        [.. ((workspaceSnapshot?.Timeline ?? []).Concat(this.clientTimelineEntries)).OrderByDescending(x => x.Timestamp)];

    private bool CanAssign => ActiveItem is not null && !string.IsNullOrWhiteSpace(workerUserIdInput);

    private bool CanReassign => CanAssign && !string.Equals(workerUserIdInput.Trim(), ActiveItem?.AssignedWorkerId, StringComparison.Ordinal);

    private IReadOnlyList<FeedbackResponse> FeedbackEntries => workspaceSnapshot?.Feedback ?? [];

    private decimal AverageFeedbackRating => FeedbackEntries.Count == 0
        ? 0m
        : FeedbackEntries.Average(static feedback => feedback.Rating);

    protected override async Task OnInitializedAsync()
    {
        realtimeConnectionState = RealtimeClient.ConnectionState;
        statusSubscription = RealtimeClient.SubscribeToStatusUpdates(HandleStatusUpdatedAsync);
        assignmentSubscription = RealtimeClient.SubscribeToAssignmentUpdates(HandleAssignmentUpdatedAsync);
        RealtimeClient.ConnectionStateChanged += HandleConnectionStateChanged;
        await EnsureRealtimeConnectedAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (!string.Equals(loadedRequestId, RequestId, StringComparison.Ordinal))
        {
            clientTimelineEntries.Clear();
            workspaceMessage = null;
            workspaceError = null;
            await LoadWorkspaceAsync();
        }
    }

    public void Dispose()
    {
        statusSubscription?.Dispose();
        assignmentSubscription?.Dispose();
        RealtimeClient.ConnectionStateChanged -= HandleConnectionStateChanged;
    }

    private async Task LoadWorkspaceAsync()
    {
        try
        {
            fetchState = await Fetcher.FetchAsync(
                async () =>
                {
                    if (string.IsNullOrWhiteSpace(RequestId))
                    {
                        throw new InvalidOperationException("Select a request from the queue to open the request workspace.");
                    }

                    return await WorkspaceApiClient.GetAsync(RequestId);
                },
                fetchState,
                maxRetries: 2,
                staleThresholdSeconds: 60);

            workspaceSnapshot = fetchState.Data;
            loadedRequestId = workspaceSnapshot?.Item.RequestId;
            if (ActiveItem is not null)
            {
                workerUserIdInput = ActiveItem.AssignedWorkerId ?? workerUserIdInput;
            }
        }
        catch (Exception ex)
        {
            errorBoundary?.HandleError(ex, "Failed to load request workspace.");
        }
    }

    private async Task ReloadWorkspaceAsync()
    {
        await LoadWorkspaceAsync();
        StateHasChanged();
    }

    private async Task HandleRetry()
    {
        await LoadWorkspaceAsync();
    }

    private void HandleDismiss()
    {
        fetchState.State = FetchState.Idle;
    }

    private async Task HandleLifecycleAction(TriageAction action)
    {
        if (workspaceSnapshot is null)
        {
            return;
        }

        var nextStage = action switch
        {
            TriageAction.Complete => RequestStage.Completed,
            TriageAction.Hold => RequestStage.OnHold,
            TriageAction.Reopen => RequestStage.New,
            TriageAction.Reject => RequestStage.Cancelled,
            _ => (RequestStage?)null,
        };

        if (nextStage is null)
        {
            return;
        }

        await ExecuteMutationAsync(
            () => WorkspaceApiClient.TransitionStatusAsync(workspaceSnapshot.Item.RequestId, nextStage.Value, workspaceSnapshot.RowVersion),
            $"Lifecycle action applied: {action}.");
    }

    private async Task AssignWorkerAsync()
    {
        if (workspaceSnapshot is null)
        {
            return;
        }

        var workerUserId = workerUserIdInput.Trim();
        if (string.IsNullOrWhiteSpace(workerUserId))
        {
            workspaceError = "Enter a worker user id before assigning the request.";
            return;
        }

        await ExecuteMutationAsync(
            () => WorkspaceApiClient.AssignWorkerAsync(workspaceSnapshot.Item.RequestId, workerUserId, workspaceSnapshot.RowVersion, false),
            $"Assignment updated: {workerUserId} assigned to the request.");
    }

    private async Task ReassignWorkerAsync()
    {
        if (workspaceSnapshot is null)
        {
            return;
        }

        var workerUserId = workerUserIdInput.Trim();
        if (string.IsNullOrWhiteSpace(workerUserId))
        {
            workspaceError = "Enter a worker user id before reassigning the request.";
            return;
        }

        await ExecuteMutationAsync(
            () => WorkspaceApiClient.AssignWorkerAsync(workspaceSnapshot.Item.RequestId, workerUserId, workspaceSnapshot.RowVersion, true),
            $"Assignment updated: request reassigned to {workerUserId}.");
    }

    private async Task ExecuteMutationAsync(Func<Task<RequestWorkspaceOperationResult>> operation, string timelineMessage)
    {
        try
        {
            isMutating = true;
            workspaceMessage = null;
            workspaceError = null;

            var result = await operation();
            AddClientTimelineEntry(timelineMessage);
            workspaceMessage = result.Message;
            await ReloadWorkspaceAsync();
        }
        catch (RequestWorkspaceConflictException ex)
        {
            if (workspaceSnapshot is not null && !string.IsNullOrWhiteSpace(ex.CurrentRowVersion))
            {
                workspaceSnapshot.RowVersion = ex.CurrentRowVersion;
            }

            workspaceError = $"{ex.Message} Refresh and retry.";
            AddClientTimelineEntry("Workspace refreshed after a concurrency conflict.");
            await ReloadWorkspaceAsync();
        }
        catch (RequestWorkspaceApiException ex)
        {
            workspaceError = ex.Message;
        }
        finally
        {
            isMutating = false;
        }
    }

    private void AddClientTimelineEntry(string message)
    {
        clientTimelineEntries.Add(new RequestWorkspaceTimelineEntry(Guid.NewGuid(), DateTime.UtcNow, message));
    }

    private void GoBackToQueue()
    {
        Navigation.NavigateTo("/customer-care/requests");
    }

    private static string DescribeFeedback(FeedbackResponse feedback)
    {
        var source = feedback.Source == 1 ? "Worker" : "Customer";
        var type = feedback.Type switch
        {
            0 => "Service Quality",
            1 => "Worker Behavior",
            2 => "Response Timeliness",
            3 => "Communication",
            4 => "Technical Competence",
            _ => "Other",
        };

        var rating = feedback.Rating > 0 ? $"rated {feedback.Rating:0.#}/5" : "submitted comment-only feedback";
        var actionability = feedback.IsActionable ? "Actionable" : "Informational";
        var comment = string.IsNullOrWhiteSpace(feedback.Comment) ? "No comment provided." : feedback.Comment;

        return $"{source} · {type} · {rating} · {actionability}. {comment}";
    }

    private async Task EnsureRealtimeConnectedAsync()
    {
        try
        {
            await RealtimeClient.EnsureConnectedAsync();
        }
        catch
        {
            realtimeConnectionState = RealtimeClient.ConnectionState;
        }
    }

    private Task HandleStatusUpdatedAsync(ServiceRequestStatusUpdatedEvent payload)
    {
        return InvokeAsync(() =>
        {
            if (ActiveItem is null
                || !string.Equals(ActiveItem.RequestId, payload.RequestId, StringComparison.Ordinal)
                || !OperationalRealtimeMapper.TryParseRequestStage(payload.CurrentStatus, out var currentStatus))
            {
                return;
            }

            ActiveItem.Status = currentStatus;
            ActiveItem.Stage = OperationalRealtimeMapper.MapWorkspaceStage(currentStatus);
            ActiveItem.UpdatedAtUtc = payload.UpdatedAtUtc;
            AddClientTimelineEntry($"Live update: status changed from {payload.PreviousStatus} to {payload.CurrentStatus}.");
            fetchState.LastSuccessFetchedAt = payload.UpdatedAtUtc;
            StateHasChanged();
        });
    }

    private Task HandleAssignmentUpdatedAsync(JobAssignmentUpdatedEvent payload)
    {
        return InvokeAsync(() =>
        {
            if (ActiveItem is null || !string.Equals(ActiveItem.RequestId, payload.RequestId, StringComparison.Ordinal))
            {
                return;
            }

            ActiveItem.AssignedWorkerId = payload.CurrentWorkerUserId;
            ActiveItem.AssignedWorker = payload.CurrentWorkerUserId;
            ActiveItem.UpdatedAtUtc = payload.UpdatedAtUtc;
            workerUserIdInput = payload.CurrentWorkerUserId ?? workerUserIdInput;

            if (workspaceSnapshot is not null)
            {
                workspaceSnapshot.ActiveJobStatus = payload.AssignmentStatus;
            }

            AddClientTimelineEntry($"Live update: assignment changed to {payload.CurrentWorkerUserId ?? "unassigned"}.");
            fetchState.LastSuccessFetchedAt = payload.UpdatedAtUtc;
            StateHasChanged();
        });
    }

    private void HandleConnectionStateChanged(OperationalRealtimeConnectionState newState)
    {
        _ = InvokeAsync(() =>
        {
            realtimeConnectionState = newState;
            StateHasChanged();
        });
    }
}
