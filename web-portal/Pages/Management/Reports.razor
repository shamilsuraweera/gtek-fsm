@page "/management/reports"

@using GTEK.FSM.WebPortal.Components
@using GTEK.FSM.WebPortal.Models
@using GTEK.FSM.WebPortal.Services
@using GTEK.FSM.WebPortal.Services.Management
@using GTEK.FSM.Shared.Contracts.Api.Contracts.Reports.Responses

@inject ResilientDataFetcher Fetcher
@inject IManagementReportsApiClient ReportsApiClient

<PageTitle>Management Reports</PageTitle>

<h1>Management Reports</h1>

<ResilienceErrorBoundary @ref="errorBoundary">
	<DataFetchStateDisplay
		State="@fetchState.State"
		LoadingMessage="Loading governance analytics..."
		ErrorMessage="@fetchState.ErrorMessage"
		StaleMessage="Analytics are cached; live governance insights may lag."
		PartialMessage="Analytics loaded with partial context."
		RetryingMessage="@($"Retrying analytics... Attempt {fetchState.RetryAttempts}")"
		AllowStaleRender="true"
		OnRetry="@HandleRetry"
		OnDismiss="@HandleDismiss">

		@if (Overview is not null)
		{
			<section class="analytics-shell">
				<section class="analytics-controls">
					<label>Window (days)</label>
					<select @bind="WindowDays">
						<option value="7">7</option>
						<option value="14">14</option>
						<option value="30">30</option>
					</select>
					<label>Trend Buckets</label>
					<select @bind="TrendBuckets">
						<option value="7">7</option>
						<option value="10">10</option>
						<option value="14">14</option>
					</select>
					<button @onclick="ReloadAsync">Refresh</button>
				</section>

				<section class="audit-summary-grid">
					<article class="audit-summary-card">
						<p class="audit-summary-label">Requests in Window</p>
						<p class="audit-summary-value">@Overview.TotalRequestsInWindow</p>
					</article>
					<article class="audit-summary-card">
						<p class="audit-summary-label">Completed in Window</p>
						<p class="audit-summary-value">@Overview.CompletedRequestsInWindow</p>
					</article>
					<article class="audit-summary-card">
						<p class="audit-summary-label">Active Jobs</p>
						<p class="audit-summary-value">@Overview.ActiveJobs</p>
					</article>
					<article class="audit-summary-card">
						<p class="audit-summary-label">Sensitive Actions (24h)</p>
						<p class="audit-summary-value">@Overview.SensitiveActions24h</p>
					</article>
					<article class="audit-summary-card">
						<p class="audit-summary-label">Denied Actions (24h)</p>
						<p class="audit-summary-value">@Overview.DeniedActions24h</p>
					</article>
					<article class="audit-summary-card">
						<p class="audit-summary-label">Assignment Acceptance</p>
						<p class="audit-summary-value">@FormatPercent(Overview.AssignmentQuality.AcceptanceRatePercent)</p>
					</article>
					<article class="audit-summary-card">
						<p class="audit-summary-label">Worker Utilization</p>
						<p class="audit-summary-value">@FormatPercent(Overview.WorkforceUtilization.UtilizationRatePercent)</p>
					</article>
				</section>

				<section class="trend-grid">
					<article class="audit-panel">
						<header class="audit-panel-header">
							<h2>SLA Posture</h2>
						</header>
						<div class="insight-metric-grid">
							<div class="insight-metric-card">
								<span class="audit-summary-label">Response</span>
								<strong>@Overview.DecisioningMetrics.SlaOutcomes.ResponseOnTrack / @Overview.DecisioningMetrics.SlaOutcomes.ResponseAtRisk / @Overview.DecisioningMetrics.SlaOutcomes.ResponseBreached</strong>
								<span class="audit-muted">On track / at risk / breached</span>
							</div>
							<div class="insight-metric-card">
								<span class="audit-summary-label">Assignment</span>
								<strong>@Overview.DecisioningMetrics.SlaOutcomes.AssignmentOnTrack / @Overview.DecisioningMetrics.SlaOutcomes.AssignmentAtRisk / @Overview.DecisioningMetrics.SlaOutcomes.AssignmentBreached</strong>
								<span class="audit-muted">On track / at risk / breached</span>
							</div>
							<div class="insight-metric-card">
								<span class="audit-summary-label">Completion</span>
								<strong>@Overview.DecisioningMetrics.SlaOutcomes.CompletionOnTrack / @Overview.DecisioningMetrics.SlaOutcomes.CompletionAtRisk / @Overview.DecisioningMetrics.SlaOutcomes.CompletionBreached</strong>
								<span class="audit-muted">On track / at risk / breached</span>
							</div>
							<div class="insight-metric-card">
								<span class="audit-summary-label">Escalations</span>
								<strong>@Overview.DecisioningMetrics.SlaOutcomes.EscalationsAtRiskInWindow / @Overview.DecisioningMetrics.SlaOutcomes.EscalationsBreachedInWindow</strong>
								<span class="audit-muted">At risk / breached in window</span>
							</div>
						</div>
					</article>

					<article class="audit-panel">
						<header class="audit-panel-header">
							<h2>Assignment Quality</h2>
						</header>
						<div class="insight-metric-grid">
							<div class="insight-metric-card">
								<span class="audit-summary-label">Assignment Events</span>
								<strong>@Overview.AssignmentQuality.AssignmentEventsInWindow</strong>
							</div>
							<div class="insight-metric-card">
								<span class="audit-summary-label">Accepted</span>
								<strong>@Overview.AssignmentQuality.AcceptedJobs</strong>
							</div>
							<div class="insight-metric-card">
								<span class="audit-summary-label">Pending Acceptance</span>
								<strong>@Overview.AssignmentQuality.PendingAcceptanceJobs</strong>
							</div>
							<div class="insight-metric-card">
								<span class="audit-summary-label">Completed</span>
								<strong>@Overview.AssignmentQuality.CompletedJobs</strong>
							</div>
							<div class="insight-metric-card">
								<span class="audit-summary-label">Rejected</span>
								<strong>@Overview.AssignmentQuality.RejectedJobs</strong>
							</div>
							<div class="insight-metric-card">
								<span class="audit-summary-label">Completion Rate</span>
								<strong>@FormatPercent(Overview.AssignmentQuality.CompletionRatePercent)</strong>
							</div>
						</div>
						<div class="audit-table-wrap compact-table-wrap">
							<table class="audit-table">
								<thead>
									<tr>
										<th>Status</th>
										<th>Count</th>
									</tr>
								</thead>
								<tbody>
									@foreach (var item in Overview.AssignmentQuality.StatusDrilldown)
									{
										<tr>
											<td>@item.Key</td>
											<td>@item.Count</td>
										</tr>
									}
								</tbody>
							</table>
						</div>
					</article>
				</section>

				<section class="trend-grid">
					<article class="audit-panel">
						<header class="audit-panel-header">
							<h2>Worker Utilization</h2>
						</header>
						<div class="insight-metric-grid">
							<div class="insight-metric-card">
								<span class="audit-summary-label">Active Workers</span>
								<strong>@Overview.WorkforceUtilization.ActiveWorkers</strong>
							</div>
							<div class="insight-metric-card">
								<span class="audit-summary-label">Available</span>
								<strong>@Overview.WorkforceUtilization.AvailableWorkers</strong>
							</div>
							<div class="insight-metric-card">
								<span class="audit-summary-label">Busy</span>
								<strong>@Overview.WorkforceUtilization.BusyWorkers</strong>
							</div>
							<div class="insight-metric-card">
								<span class="audit-summary-label">Utilized</span>
								<strong>@Overview.WorkforceUtilization.UtilizedWorkers</strong>
							</div>
							<div class="insight-metric-card">
								<span class="audit-summary-label">Overloaded</span>
								<strong>@Overview.WorkforceUtilization.OverloadedWorkers</strong>
							</div>
							<div class="insight-metric-card">
								<span class="audit-summary-label">Avg Active Jobs / Utilized Worker</span>
								<strong>@Overview.WorkforceUtilization.AverageActiveJobsPerUtilizedWorker.ToString("0.00")</strong>
							</div>
						</div>
					</article>

					<article class="audit-panel">
						<header class="audit-panel-header">
							<h2>Availability and Load</h2>
						</header>
						<div class="audit-table-wrap compact-table-wrap">
							<table class="audit-table">
								<thead>
									<tr>
										<th>Availability</th>
										<th>Count</th>
									</tr>
								</thead>
								<tbody>
									@foreach (var item in Overview.WorkforceUtilization.AvailabilityDrilldown)
									{
										<tr>
											<td>@item.Key</td>
											<td>@item.Count</td>
										</tr>
									}
								</tbody>
							</table>
						</div>
						<div class="audit-table-wrap compact-table-wrap">
							<table class="audit-table">
								<thead>
									<tr>
										<th>Load Band</th>
										<th>Count</th>
									</tr>
								</thead>
								<tbody>
									@foreach (var item in Overview.WorkforceUtilization.WorkerLoadDrilldown)
									{
										<tr>
											<td>@item.Key</td>
											<td>@item.Count</td>
										</tr>
									}
								</tbody>
							</table>
						</div>
						<p class="audit-muted">Average internal rating: @Overview.WorkforceUtilization.AverageInternalRating.ToString("0.00")</p>
					</article>
				</section>

				<section class="trend-grid">
					<article class="audit-panel">
						<header class="audit-panel-header">
							<h2>Request Intake Trend</h2>
						</header>
						<div class="trend-bars">
							@foreach (var point in Overview.IntakeTrend)
							{
								<div class="trend-bar-wrap" title="@point.DateUtc.ToString("yyyy-MM-dd")">
									<span class="trend-bar" style="height:@NormalizeHeight(Overview.IntakeTrend, point)%"></span>
									<span class="trend-label">@point.DateUtc.ToString("MM-dd")</span>
								</div>
							}
						</div>
					</article>

					<article class="audit-panel">
						<header class="audit-panel-header">
							<h2>Completion Trend</h2>
						</header>
						<div class="trend-bars">
							@foreach (var point in Overview.CompletionTrend)
							{
								<div class="trend-bar-wrap" title="@point.DateUtc.ToString("yyyy-MM-dd")">
									<span class="trend-bar completion" style="height:@NormalizeHeight(Overview.CompletionTrend, point)%"></span>
									<span class="trend-label">@point.DateUtc.ToString("MM-dd")</span>
								</div>
							}
						</div>
					</article>
				</section>

				<section class="audit-panel">
					<header class="audit-panel-header">
						<h2>Anomaly Indicators</h2>
					</header>
					<div class="oversight-list">
						@foreach (var anomaly in Overview.Anomalies)
						{
							<article class="oversight-item">
								<div>
									<p class="oversight-title">@anomaly.Code</p>
									<p class="audit-muted">@anomaly.Message</p>
								</div>
								<span class="audit-pill @GetRiskClass(anomaly.Severity)">@anomaly.Severity</span>
							</article>
						}
					</div>
				</section>

				<section class="audit-panel">
					<header class="audit-panel-header">
						<h2>Continuous Improvement Cadence</h2>
					</header>
					<p class="audit-muted">@Overview.ContinuousImprovement.CadenceName for the last @Overview.ContinuousImprovement.ReviewWindowDays day(s). Next review: @Overview.ContinuousImprovement.NextReviewOnUtc.ToLocalTime().ToString("yyyy-MM-dd")</p>
					<p class="audit-muted">@Overview.ContinuousImprovement.PrioritizationRule</p>

					@if (Overview.ContinuousImprovement.ImprovementItems.Count == 0)
					{
						<p class="workspace-hint">No KPI regressions currently require backlog action. Keep monitoring the existing trend and anomaly views.</p>
					}
					else
					{
						<div class="oversight-list">
							@foreach (var item in Overview.ContinuousImprovement.ImprovementItems)
							{
								<article class="oversight-item improvement-item">
									<div>
										<p class="oversight-title">@item.Code</p>
										<p class="audit-muted"><strong>@item.Metric</strong> · @item.CurrentState</p>
										<p class="audit-muted">Target: @item.TargetState</p>
										<p class="audit-muted">Action: @item.RecommendedAction</p>
										<p class="audit-muted">Owner: @item.ReviewOwner</p>
									</div>
									<span class="audit-pill @GetRiskClass(item.Priority)">@item.Priority</span>
								</article>
							}
						</div>
					}
				</section>

				<section class="trend-grid">
					<article class="audit-panel">
						<header class="audit-panel-header">
							<h2>Action Drill-down</h2>
						</header>
						<div class="audit-table-wrap">
							<table class="audit-table">
								<thead>
									<tr>
										<th>Action</th>
										<th>Count</th>
									</tr>
								</thead>
								<tbody>
									@foreach (var item in Overview.ActionDrilldown)
									{
										<tr>
											<td>@item.Key</td>
											<td>@item.Count</td>
										</tr>
									}
								</tbody>
							</table>
						</div>
					</article>

					<article class="audit-panel">
						<header class="audit-panel-header">
							<h2>Outcome Drill-down</h2>
						</header>
						<div class="audit-table-wrap">
							<table class="audit-table">
								<thead>
									<tr>
										<th>Outcome</th>
										<th>Count</th>
									</tr>
								</thead>
								<tbody>
									@foreach (var item in Overview.OutcomeDrilldown)
									{
										<tr>
											<td>@item.Key</td>
											<td>@item.Count</td>
										</tr>
									}
								</tbody>
							</table>
						</div>
					</article>
				</section>
			</section>
		}
	</DataFetchStateDisplay>
</ResilienceErrorBoundary>

@code {
	private ResilienceErrorBoundary? errorBoundary;
	private FetchResult<GetManagementAnalyticsOverviewResponse> fetchState = new();
	private int WindowDays { get; set; } = 7;
	private int TrendBuckets { get; set; } = 7;
	private GetManagementAnalyticsOverviewResponse? Overview => fetchState.Data;

	protected override async Task OnInitializedAsync()
	{
		await this.LoadOverviewAsync();
	}

	private async Task ReloadAsync()
	{
		await this.LoadOverviewAsync();
	}

	private async Task LoadOverviewAsync()
	{
		try
		{
			fetchState = await Fetcher.FetchAsync(
				async () =>
				{
					return await ReportsApiClient.GetOverviewAsync(WindowDays, TrendBuckets);
				},
				fetchState,
				maxRetries: 2,
				staleThresholdSeconds: 90);
		}
		catch (ManagementReportsApiException ex)
		{
			errorBoundary?.HandleError(ex, ex.Message);
		}
		catch (Exception ex)
		{
			errorBoundary?.HandleError(ex, "Failed to load governance analytics.");
		}
	}

	private async Task HandleRetry()
	{
		await this.LoadOverviewAsync();
	}

	private void HandleDismiss()
	{
		fetchState.State = FetchState.Idle;
	}

	private static string GetRiskClass(string risk)
	{
		if (risk.Equals("High", StringComparison.OrdinalIgnoreCase))
		{
			return "high";
		}

		if (risk.Equals("Medium", StringComparison.OrdinalIgnoreCase))
		{
			return "medium";
		}

		return "low";
	}

	private static decimal NormalizeHeight(IReadOnlyList<ManagementTrendPointResponse> points, ManagementTrendPointResponse current)
	{
		if (points.Count == 0)
		{
			return 15;
		}

		var max = Math.Max(1, points.Max(x => x.Value));
		var ratio = (decimal)current.Value / max;
		return Math.Clamp(ratio * 100m, 15m, 100m);
	}

	private static string FormatPercent(decimal value)
	{
		return $"{value:0.##}%";
	}
}

<style>
	.analytics-shell {
		display: grid;
		gap: 1rem;
	}

	.analytics-controls {
		display: flex;
		gap: 0.5rem;
		align-items: center;
		flex-wrap: wrap;
	}

	.trend-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
		gap: 1rem;
	}

	.trend-bars {
		display: flex;
		align-items: end;
		gap: 0.5rem;
		min-height: 160px;
	}

	.trend-bar-wrap {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.25rem;
		min-width: 36px;
	}

	.trend-bar {
		display: inline-block;
		width: 20px;
		background: #2f6fdd;
		border-radius: 4px 4px 0 0;
	}

	.trend-bar.completion {
		background: #039855;
	}

	.trend-label {
		font-size: 0.75rem;
		color: #475467;
	}

	.insight-metric-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
		gap: 0.75rem;
	}

	.insight-metric-card {
		display: grid;
		gap: 0.35rem;
		padding: 0.85rem;
		border: 1px solid #d0d5dd;
		border-radius: 0.75rem;
		background: #f8fafc;
	}

	.compact-table-wrap {
		margin-top: 1rem;
	}

	.improvement-item {
		align-items: flex-start;
	}
</style>
