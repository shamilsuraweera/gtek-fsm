@namespace GTEK.FSM.WebPortal.Components

@using GTEK.FSM.WebPortal.Models

<div class="data-fetch-state-container">
	@switch (State)
	{
		case FetchState.Loading:
			<div class="fetch-state fetch-state-loading">
				<div class="loading-spinner"></div>
				<p>@(LoadingMessage ?? "Loading data...")</p>
			</div>
			break;

		case FetchState.Success:
			@ChildContent
			break;

		case FetchState.Stale:
			<div class="fetch-state fetch-state-stale">
				<div class="stale-badge">
					<span class="stale-icon">⚠️</span>
					<span>Cached (Stale)</span>
				</div>
				<p>@(StaleMessage ?? "Showing cached data from earlier. Data may be out of date.")</p>
				<div class="state-actions">
					@if (OnRetry.HasDelegate)
					{
						<button class="btn-retry" @onclick="OnRetry">Refresh Now</button>
					}
				</div>
				@if (AllowStaleRender)
				{
					<div class="stale-content">
						@ChildContent
					</div>
				}
			</div>
			break;

		case FetchState.Error:
			<div class="fetch-state fetch-state-error">
				<div class="error-badge">
					<span class="error-icon">❌</span>
					<span>Load Failed</span>
				</div>
				<p>@(ErrorMessage ?? "Unable to load data.")</p>
				<div class="state-actions">
					@if (OnRetry.HasDelegate)
					{
						<button class="btn-retry" @onclick="OnRetry">Try Again</button>
					}
					@if (OnDismiss.HasDelegate)
					{
						<button class="btn-dismiss" @onclick="OnDismiss">Dismiss</button>
					}
				</div>
			</div>
			break;

		case FetchState.Retrying:
			<div class="fetch-state fetch-state-retrying">
				<div class="retry-spinner"></div>
				<p>@(RetryingMessage ?? $"Retrying... Attempt {RetryAttempt ?? 1}")</p>
			</div>
			break;

		case FetchState.PartialSuccess:
			<div class="fetch-state fetch-state-partial">
				<div class="partial-badge">
					<span class="partial-icon">⚡</span>
					<span>Partial Data</span>
				</div>
				<p>@(PartialMessage ?? "Some data loaded; other items failed. Showing available items.")</p>
				<div class="state-actions">
					@if (OnRetry.HasDelegate)
					{
						<button class="btn-retry" @onclick="OnRetry">Retry Failed Items</button>
					}
				</div>
				<div class="partial-content">
					@ChildContent
				</div>
			</div>
			break;

		case FetchState.Idle:
		default:
			@ChildContent
			break;
	}
</div>

@code {
	[Parameter]
	public FetchState State { get; set; } = FetchState.Idle;

	[Parameter]
	public RenderFragment? ChildContent { get; set; }

	[Parameter]
	public EventCallback OnRetry { get; set; }

	[Parameter]
	public EventCallback OnDismiss { get; set; }

	[Parameter]
	public string? LoadingMessage { get; set; }

	[Parameter]
	public string? ErrorMessage { get; set; }

	[Parameter]
	public string? StaleMessage { get; set; }

	[Parameter]
	public string? PartialMessage { get; set; }

	[Parameter]
	public string? RetryingMessage { get; set; }

	[Parameter]
	public int? RetryAttempt { get; set; }

	/// <summary>
	/// When true, renders ChildContent even in Stale state. Useful for showing data while stale indicator is visible.
	/// </summary>
	[Parameter]
	public bool AllowStaleRender { get; set; } = true;
}
