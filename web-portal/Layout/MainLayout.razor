@inherits LayoutComponentBase
@implements IDisposable
@inject GTEK.FSM.WebPortal.Services.Theme.ThemeState ThemeState

<div class="page">
    <header class="top-bar px-4">
        <div class="portal-header">
            <strong>GTEK FSM Portal</strong>
            <span class="portal-subtitle">Customer Care and Management shell</span>
        </div>
        <button class="theme-toggle" @onclick="ToggleThemeAsync">
            Theme: @CurrentThemeLabel
        </button>
    </header>

    <aside class="side-nav">
        <NavMenu />
    </aside>

    <main class="content-area">
        <article class="content px-4">
            @Body
        </article>
    </main>

    <aside class="right-drawer px-3">
        <h2>Right Drawer</h2>
        <p>Placeholder container for contextual tools and details.</p>
    </aside>
</div>

@code {
    private bool _initialized;

    private string CurrentThemeLabel => ThemeState.CurrentMode == GTEK.FSM.WebPortal.Services.Theme.ThemeMode.Dark
        ? "Dark"
        : "Light";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_initialized)
        {
            _initialized = true;
            await ThemeState.InitializeAsync();
            StateHasChanged();
        }
    }

    private async Task ToggleThemeAsync()
    {
        await ThemeState.ToggleAsync();
    }

    public void Dispose()
    {
    }
}
