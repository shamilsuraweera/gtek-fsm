@inherits LayoutComponentBase
@implements IDisposable
@inject GTEK.FSM.WebPortal.Services.Theme.ThemeState ThemeState
@inject GTEK.FSM.WebPortal.Services.Security.PortalAuthState AuthState
@inject NavigationManager Navigation

<div class="page">
    <header class="top-bar px-4">
        <div class="portal-header">
            <strong>GTEK FSM Portal</strong>
            <span class="portal-subtitle">@HeaderSubtitle</span>
        </div>
        <div class="d-flex align-items-center gap-2">
            <span class="portal-subtitle">@AuthState.Session?.DisplayName (@AuthState.CurrentRole)</span>
            <button class="theme-toggle" @onclick="ToggleThemeAsync">
                Theme: @CurrentThemeLabel
            </button>
            <button class="theme-toggle" @onclick="LogoutAsync">
                Logout
            </button>
        </div>
    </header>

    <aside class="side-nav">
        <NavMenu />
    </aside>

    <main class="content-area">
        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

@code {
    private bool _initialized;

    private string CurrentThemeLabel => ThemeState.CurrentMode == GTEK.FSM.WebPortal.Services.Theme.ThemeMode.Dark
        ? "Dark"
        : "Light";

    private string HeaderSubtitle => string.IsNullOrWhiteSpace(AuthState.CurrentTenantId)
        ? "Customer Care and Management shell"
        : $"Tenant {AuthState.CurrentTenantId}";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_initialized)
        {
            _initialized = true;
            await ThemeState.InitializeAsync();
            StateHasChanged();
        }
    }

    private async Task ToggleThemeAsync()
    {
        await ThemeState.ToggleAsync();
    }

    private async Task LogoutAsync()
    {
        await AuthState.LogoutAsync();
        Navigation.NavigateTo("/login", replace: true);
    }

    public void Dispose()
    {
    }
}
